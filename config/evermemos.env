# EverMemOS Environment Configuration
LLM_PROVIDER=openai
LLM_MODEL=qwen3.5-plus
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=32768

VECTORIZE_PROVIDER=deepinfra
VECTORIZE_API_KEY=your-api-key-here
VECTORIZE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
VECTORIZE_MODEL=kimi-k2.5
VECTORIZE_FALLBACK_PROVIDER=none
VECTORIZE_DIMENSIONS=1024

RERANK_PROVIDER=deepinfra
RERANK_API_KEY=your-api-key-here
RERANK_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
RERANK_MODEL=kimi-k2.5
RERANK_FALLBACK_PROVIDER=none

MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=root
MONGODB_PASSWORD=miromem
MONGODB_DATABASE=miromem
MONGODB_URI_PARAMS=socketTimeoutMS=15000&authSource=admin

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_SSL=false

ES_HOSTS=http://elasticsearch:9200
ES_VERIFY_CERTS=false
SELF_ES_INDEX_NS=miromem

MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
SELF_MILVUS_COLLECTION_NS=miromem

LOG_LEVEL=INFO
ENV=dev
MEMORY_LANGUAGE=en
