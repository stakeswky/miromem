# ============================================================
# MiroMem Environment Configuration
# ============================================================

# --- Gateway ---
GATEWAY_PORT=8000

# --- EverMemOS Service ---
EVERMEMOS_HOST=evermemos
EVERMEMOS_PORT=1995

# --- MiroFish Backend ---
MIROFISH_HOST=mirofish-backend
MIROFISH_PORT=5001

# --- LLM Provider (OpenAI-compatible) ---
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://oogg.top/v1
LLM_MODEL=claude-haiku-4-6

# --- Embedding Model ---
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_BASE_URL=https://oogg.top/v1
EMBEDDING_MODEL=claude-haiku-4-6

# --- Reranker Model ---
RERANKER_API_KEY=your-api-key-here
RERANKER_BASE_URL=https://oogg.top/v1
RERANKER_MODEL=claude-haiku-4-6

# --- MongoDB ---
MONGODB_URI=mongodb://root:miromem@mongodb:27017
MONGODB_DB=miromem

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Milvus ---
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- MiroFish Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api
