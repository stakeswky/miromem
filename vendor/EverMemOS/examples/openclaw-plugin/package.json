{
  "name": "@evermind-ai/openclaw-plugin",
  "version": "1.4.0",
  "description": "EverOS OpenClaw Plugin for OpenClaw 3.8+",
  "type": "module",
  "main": "./index.js",
  "bin": {
    "everos-install": "./bin/install.js"
  },
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "README.md",
    "README.zh.md",
    "SKILL.md",
    "bin/",
    "src/"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "context-engine",
    "memory",
    "everos",
    "ai",
    "agent"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "id": "evermind-ai-everos",
    "kind": "context-engine",
    "contextEngine": true
  }
}
