# ============================================================
# MiroMem Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Gateway ---
GATEWAY_PORT=8000

# --- EverMemOS Service ---
EVERMEMOS_HOST=evermemos
EVERMEMOS_PORT=1995

# --- MiroFish Backend ---
MIROFISH_HOST=mirofish-backend
MIROFISH_PORT=5001

# --- Graph Backend Rollout ---
GRAPH_BACKEND=zep
GRAPH_SERVICE_BASE_URL=http://graph-service:8001
GRAPH_SERVICE_PORT=8001

# --- Graph Service LLM Provider ---
GRAPH_LLM_API_KEY=your-graph-llm-key
GRAPH_LLM_BASE_URL=https://openrouter.ai/api/v1
GRAPH_LLM_MODEL=x-ai/grok-4-fast

# --- Graph Service Embedding Provider ---
GRAPH_EMBEDDING_API_KEY=your-graph-embedding-key
GRAPH_EMBEDDING_BASE_URL=https://api.deepinfra.com/v1/openai
GRAPH_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
GRAPH_EMBEDDING_DIM=3072

# --- Graph Service Reranker ---
GRAPH_RERANKER_PROVIDER=disabled
GRAPH_RERANKER_API_KEY=
GRAPH_RERANKER_BASE_URL=
GRAPH_RERANKER_MODEL=

# --- FalkorDB ---
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
FALKORDB_DATABASE=miromem_graph
FALKORDB_USERNAME=
FALKORDB_PASSWORD=

# --- LLM Provider (OpenAI-compatible) ---
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen3.5-plus

# --- Thinker Providers ---
THINKER_LLM_API_KEY=
THINKER_LLM_BASE_URL=
THINKER_LLM_MODEL=
THINKER_SEARCH_API_KEY=
THINKER_SEARCH_BASE_URL=
THINKER_SCRAPE_API_KEY=
THINKER_SCRAPE_BASE_URL=

# --- Embedding Model ---
EMBEDDING_API_KEY=your-embedding-key
EMBEDDING_BASE_URL=https://api.deepinfra.com/v1/openai
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B

# --- Reranker Model ---
RERANKER_API_KEY=your-reranker-key
RERANKER_BASE_URL=https://api.deepinfra.com/v1/openai
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B

# --- MongoDB ---
MONGODB_URI=mongodb://root:miromem@mongodb:27017
MONGODB_DB=miromem

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Milvus ---
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- MiroFish Frontend ---
# Keep this at the gateway host root. Frontend requests already include `/api/...`.
VITE_API_BASE_URL=http://localhost:8000
